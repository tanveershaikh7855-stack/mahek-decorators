<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MAHEK DECORATOR — Premium Balloon Decorations, Pune</title>
<meta name="description" content="Premium balloon decoration services across Pune and nearby cities. Transform every celebration into a memory with Mahek Decorators.">
<meta name="keywords" content="balloon decoration, balloon decorators, balloon decoration in pune, party decoration, wedding decoration, event decoration">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://api.fontshare.com/v2/css?f[]=clash-display@200,300,400,500,600,700&display=swap" rel="stylesheet">
<link href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
<style>
:root {
  --primary: #111111;
  --secondary: #F5F5F2;
  --accent: #D4AF37;
  --accent-light: #E8C84A;
  --accent-dark: #B8962E;
  --white: #FFFFFF;
  --light-gray: #E8E8E5;
  --charcoal: #2A2A2A;
  --gray-100: #F7F7F5;
  --gray-200: #EDEDE8;
  --gray-300: #D4D4CF;
  --gray-400: #A0A09C;
  --gray-500: #6B6B68;
  --gray-600: #4A4A48;
  --font-display: 'Clash Display', sans-serif;
  --font-body: 'Inter', sans-serif;
  --font-ui: 'Satoshi', sans-serif;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: auto; }
body { font-family: var(--font-body); background: var(--white); color: var(--primary); overflow-x: hidden; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
h1,h2,h3,h4,h5,h6 { font-family: var(--font-display); font-weight: 600; line-height: 1.1; letter-spacing: -0.02em; }
.font-ui { font-family: var(--font-ui); }

.loader { position: fixed; inset:0; z-index:9999; background:var(--primary); display:flex; flex-direction:column; align-items:center; justify-content:center; transition: opacity 0.8s ease, visibility 0.8s ease; }
.loader.hidden { opacity:0; visibility:hidden; }
.loader-ring { width:60px; height:60px; border:2px solid rgba(212,175,55,0.1); border-top-color:var(--accent); border-radius:50%; animation: spin 1s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }
.loader-text { font-family:var(--font-display); color:var(--accent); margin-top:24px; font-size:14px; letter-spacing:0.15em; text-transform:uppercase; }

.nav { position:fixed; top:0; left:0; right:0; z-index:1000; padding:20px 40px; display:flex; align-items:center; justify-content:space-between; transition: all 0.5s cubic-bezier(0.16,1,0.3,1); }
.nav.scrolled { background:rgba(17,17,17,0.92); backdrop-filter:blur(24px) saturate(1.4); -webkit-backdrop-filter:blur(24px) saturate(1.4); padding:14px 40px; border-bottom:1px solid rgba(255,255,255,0.04); }
.nav-logo { font-family:var(--font-display); font-size:22px; font-weight:700; color:var(--white); letter-spacing:-0.03em; text-decoration:none; }
.nav-logo span { color:var(--accent); }
.nav-links { display:flex; align-items:center; gap:32px; list-style:none; }
.nav-links a { font-family:var(--font-ui); font-size:14px; color:rgba(255,255,255,0.7); text-decoration:none; transition:color 0.3s; position:relative; }
.nav-links a:hover { color:var(--white); }
.nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:1px; background:var(--accent); transition:width 0.4s cubic-bezier(0.16,1,0.3,1); }
.nav-links a:hover::after { width:100%; }
.nav-cta { background:var(--accent); color:var(--primary) !important; padding:8px 20px; border-radius:100px; font-weight:500; font-size:13px !important; transition: all 0.3s !important; }
.nav-cta:hover { background:var(--accent-light) !important; transform:translateY(-1px); }
.nav-cta::after { display:none !important; }
.nav-mobile-btn { display:none; flex-direction:column; gap:5px; cursor:pointer; background:none; border:none; padding:4px; }
.nav-mobile-btn span { width:24px; height:1.5px; background:var(--white); transition:all 0.3s; border-radius:2px; }
.nav-mobile-btn.active span:nth-child(1) { transform:rotate(45deg) translate(4px,5px); }
.nav-mobile-btn.active span:nth-child(2) { opacity:0; }
.nav-mobile-btn.active span:nth-child(3) { transform:rotate(-45deg) translate(4px,-5px); }

.hero { position:relative; height:100vh; background:#050505; overflow:hidden; }
#hero-canvas { position:absolute; inset:0; width:100%; height:100%; z-index:1; display:block; }
.hero-overlay { position:absolute; inset:0; background: radial-gradient(ellipse at center, transparent 30%, rgba(5,5,5,0.7) 70%, #050505 100%); z-index:2; pointer-events:none; }
.hero-content { position:relative; z-index:3; text-align:center; max-width:900px; padding:0 24px; }
.hero-badge { display:inline-flex; align-items:center; gap:8px; padding:8px 20px; border:1px solid rgba(212,175,55,0.25); border-radius:100px; font-family:var(--font-ui); font-size:12px; color:var(--accent); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:32px; backdrop-filter:blur(8px); background:rgba(212,175,55,0.05); }
.hero-badge-dot { width:6px; height:6px; background:var(--accent); border-radius:50%; animation:pulse-dot 2s ease-in-out infinite; }
@keyframes pulse-dot { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
.hero h1 { font-size:clamp(48px,8vw,96px); color:var(--white); margin-bottom:20px; line-height:1.05; will-change:transform; }
.hero h1 .accent { color:var(--accent); }
.hero p { font-family:var(--font-ui); font-size:clamp(16px,2vw,22px); color:rgba(255,255,255,0.6); line-height:1.6; max-width:600px; margin:0 auto 40px; font-weight:300; }
.hero-actions { display:flex; gap:16px; justify-content:center; flex-wrap:wrap; }
.btn { font-family:var(--font-ui); font-size:14px; font-weight:500; padding:14px 32px; border-radius:100px; text-decoration:none; transition: all 0.4s cubic-bezier(0.16,1,0.3,1); cursor:pointer; border:none; display:inline-flex; align-items:center; gap:8px; }
.btn-primary { background:var(--accent); color:var(--primary); }
.btn-primary:hover { background:var(--accent-light); transform:translateY(-2px); box-shadow:0 12px 32px rgba(212,175,55,0.25); }
.btn-outline { border:1px solid rgba(255,255,255,0.2); color:var(--white); background:transparent; }
.btn-outline:hover { border-color:var(--accent); color:var(--accent); transform:translateY(-2px); background:rgba(212,175,55,0.08); }
.btn-dark { background:var(--primary); color:var(--white); }
.btn-dark:hover { background:var(--charcoal); transform:translateY(-2px); }
.hero-scroll { position:absolute; bottom:40px; left:50%; transform:translateX(-50%); z-index:3; display:flex; flex-direction:column; align-items:center; gap:8px; color:rgba(255,255,255,0.3); font-size:11px; font-family:var(--font-ui); letter-spacing:0.15em; text-transform:uppercase; }
.hero-scroll-line { width:1px; height:40px; background:linear-gradient(to bottom, rgba(255,255,255,0.3), transparent); animation:scrollLine 2s ease-in-out infinite; }
@keyframes scrollLine { 0%,100% { transform:scaleY(0.3); opacity:0.3; } 50% { transform:scaleY(1); opacity:1; } }

.hero-float-balloon { position:absolute; z-index:2; pointer-events:none; }
.bal { width:80px; height:100px; background: radial-gradient(ellipse at 35% 35%, rgba(212,175,55,0.4), rgba(212,175,55,0.1)); border-radius:50% 50% 50% 50% / 45% 45% 55% 55%; transform-origin:center bottom; animation:float 4s ease-in-out infinite; position:relative; }
.bal::after { content:''; position:absolute; bottom:-12px; left:50%; transform:translateX(-50%); width:1px; height:30px; background:rgba(212,175,55,0.3); }
.bal-string { position:absolute; bottom:-12px; left:50%; width:1px; background:linear-gradient(to bottom, rgba(212,175,55,0.4), transparent); transform-origin:top; }
@keyframes float { 0%,100% { transform:translateY(0px); } 50% { transform:translateY(-20px); } }

.story-section { position:relative; background:var(--white); overflow:hidden; }
.story-pin { position:relative; height:400vh; }
.story-sticky { position:sticky; top:0; height:100vh; display:flex; align-items:center; justify-content:center; overflow:hidden; background:var(--primary); }
.story-canvas { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; }
.story-content { position:relative; z-index:2; text-align:center; max-width:700px; padding:0 24px; }
.story-content h2 { font-size:clamp(36px,5vw,64px); color:var(--white); margin-bottom:16px; }
.story-content p { font-family:var(--font-ui); color:rgba(255,255,255,0.6); font-size:18px; line-height:1.7; }
.story-visual { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; }

.story-balloon { position:relative; width:120px; height:150px; }
.story-balloon .balloon-body { width:120px; height:150px; background: radial-gradient(ellipse at 35% 30%, rgba(212,175,55,0.6), rgba(212,175,55,0.15) 70%, rgba(212,175,55,0.05)); border-radius:50% 50% 50% 50% / 45% 45% 55% 55%; position:relative; }
.story-balloon .balloon-body::after { content:''; position:absolute; bottom:-8px; left:50%; transform:translateX(-50%); width:2px; height:60px; background:linear-gradient(to bottom, rgba(212,175,55,0.5), transparent); }

.story-ribbon { position:absolute; width:200px; height:8px; background:linear-gradient(90deg, transparent, var(--accent), transparent); border-radius:4px; opacity:0; transform-origin:center; }
.story-arch { position:absolute; width:300px; height:150px; border:3px solid rgba(212,175,55,0.3); border-bottom:none; border-radius:300px 300px 0 0; opacity:0; }
.story-deco { position:absolute; width:200px; height:200px; opacity:0; border-radius:50%; background:radial-gradient(circle, rgba(212,175,55,0.2), transparent); }

.story-scenes { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; }
.story-scene { position:absolute; text-align:center; max-width:500px; padding:24px; opacity:0; }
.story-scene h3 { font-family:var(--font-display); font-size:28px; color:var(--white); margin-bottom:8px; }
.story-scene p { font-family:var(--font-ui); color:rgba(255,255,255,0.5); font-size:15px; line-height:1.6; }

.section { padding:120px 0; position:relative; }
.section-dark { background:var(--primary); }
.section-light { background:var(--secondary); }
.section-white { background:var(--white); }
.container { max-width:1280px; margin:0 auto; padding:0 24px; }
.section-label { font-family:var(--font-ui); font-size:12px; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent); margin-bottom:12px; font-weight:500; }
.section-title { font-size:clamp(32px,4vw,52px); margin-bottom:16px; }
.section-subtitle { font-family:var(--font-ui); font-size:18px; color:var(--gray-500); line-height:1.7; max-width:500px; font-weight:300; }
.section-header { margin-bottom:64px; }

.occasions-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:20px; }
.occ-card { position:relative; border-radius:16px; overflow:hidden; background:var(--white); border:1px solid var(--gray-200); transition: all 0.5s cubic-bezier(0.16,1,0.3,1); cursor:pointer; }
.occ-card:hover { transform:translateY(-8px); box-shadow:0 32px 64px rgba(0,0,0,0.08); border-color:transparent; }
.occ-card-img { width:100%; height:200px; object-fit:cover; transition:transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.occ-card:hover .occ-card-img { transform:scale(1.05); }
.occ-card-body { padding:20px; }
.occ-card-body h3 { font-family:var(--font-display); font-size:18px; font-weight:600; margin-bottom:4px; }
.occ-card-body p { font-family:var(--font-ui); font-size:14px; color:var(--gray-500); line-height:1.5; }
.occ-card-price { font-family:var(--font-ui); font-size:15px; font-weight:600; color:var(--accent-dark); margin-top:12px; }

.categories { display:flex; flex-direction:column; gap:120px; }
.cat-row { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.cat-row.reverse { direction:rtl; }
.cat-row.reverse > * { direction:ltr; }
.cat-info { padding-right:40px; }
.cat-label { font-family:var(--font-ui); font-size:12px; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent); margin-bottom:8px; }
.cat-title { font-size:clamp(28px,3.5vw,42px); margin-bottom:12px; }
.cat-price { font-family:var(--font-display); font-size:32px; color:var(--accent); margin-bottom:16px; font-weight:600; }
.cat-desc { font-family:var(--font-ui); color:var(--gray-500); line-height:1.7; margin-bottom:24px; font-size:15px; }
.cat-list { list-style:none; display:flex; flex-wrap:wrap; gap:8px; }
.cat-list li { padding:6px 16px; border:1px solid var(--gray-200); border-radius:100px; font-family:var(--font-ui); font-size:13px; color:var(--gray-600); transition:all 0.3s; }
.cat-list li:hover { border-color:var(--accent); color:var(--accent-dark); background:rgba(212,175,55,0.04); }
.cat-visual { position:relative; }
.cat-visual-img { width:100%; border-radius:20px; overflow:hidden; }
.cat-visual-img img { width:100%; height:420px; object-fit:cover; transition:transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.cat-visual:hover img { transform:scale(1.03); }
.cat-badge { position:absolute; top:20px; left:20px; background:var(--primary); color:var(--white); padding:8px 16px; border-radius:100px; font-family:var(--font-ui); font-size:12px; font-weight:500; }

.gallery-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.gallery-item { position:relative; border-radius:12px; overflow:hidden; cursor:pointer; aspect-ratio:4/3; }
.gallery-item.tall { aspect-ratio:3/4; grid-row:span 2; }
.gallery-item.wide { grid-column:span 2; }
.gallery-item img { width:100%; height:100%; object-fit:cover; transition:transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.gallery-item:hover img { transform:scale(1.05); }
.gallery-overlay { position:absolute; inset:0; background:linear-gradient(to top, rgba(17,17,17,0.6), transparent); opacity:0; transition:opacity 0.4s; display:flex; align-items:flex-end; padding:20px; }
.gallery-item:hover .gallery-overlay { opacity:1; }
.gallery-overlay span { font-family:var(--font-ui); color:var(--white); font-size:14px; }

.testimonials { overflow:hidden; }
.testimonials-track { display:flex; gap:24px; animation:scroll-testimonials 40s linear infinite; }
.testimonials:hover .testimonials-track { animation-play-state:paused; }
@keyframes scroll-testimonials { 0% { transform:translateX(0); } 100% { transform:translateX(-50%); } }
.testimonial-card { min-width:380px; background:var(--white); border:1px solid var(--gray-200); border-radius:16px; padding:28px; flex-shrink:0; }
.testimonial-stars { color:var(--accent); font-size:14px; margin-bottom:12px; letter-spacing:2px; }
.testimonial-text { font-family:var(--font-ui); color:var(--gray-600); line-height:1.7; font-size:14px; margin-bottom:16px; }
.testimonial-author { display:flex; align-items:center; gap:12px; }
.testimonial-avatar { width:40px; height:40px; border-radius:50%; background:var(--gray-200); object-fit:cover; }
.testimonial-name { font-family:var(--font-ui); font-size:14px; font-weight:600; }
.testimonial-role { font-family:var(--font-ui); font-size:12px; color:var(--gray-400); }

.reel-section { position:relative; overflow:hidden; }
.reels-track { display:flex; gap:16px; }
.reel-card { min-width:240px; border-radius:12px; overflow:hidden; aspect-ratio:9/16; background:var(--primary); position:relative; cursor:pointer; }
.reel-card img,.reel-card video { width:100%; height:100%; object-fit:cover; }
.reel-play { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(17,17,17,0.3); }
.reel-play-icon { width:48px; height:48px; border:2px solid rgba(255,255,255,0.6); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-size:20px; }

.blog-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:32px; }
.blog-card { border-radius:16px; overflow:hidden; border:1px solid var(--gray-200); transition:all 0.5s cubic-bezier(0.16,1,0.3,1); cursor:pointer; }
.blog-card:hover { transform:translateY(-8px); box-shadow:0 32px 64px rgba(0,0,0,0.06); }
.blog-card-img { width:100%; height:220px; object-fit:cover; transition:transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.blog-card:hover .blog-card-img { transform:scale(1.03); }
.blog-card-body { padding:24px; }
.blog-card-tag { font-family:var(--font-ui); font-size:12px; color:var(--accent); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:8px; }
.blog-card-body h3 { font-family:var(--font-display); font-size:20px; margin-bottom:8px; }
.blog-card-body p { font-family:var(--font-ui); font-size:14px; color:var(--gray-500); line-height:1.6; }

.faq-list { max-width:800px; margin:0 auto; }
.faq-item { border-bottom:1px solid var(--gray-200); padding:0; }
.faq-q { padding:24px 0; display:flex; justify-content:space-between; align-items:center; cursor:pointer; font-family:var(--font-ui); font-size:16px; font-weight:500; color:var(--primary); transition:color 0.3s; background:none; border:none; width:100%; text-align:left; }
.faq-q:hover { color:var(--accent-dark); }
.faq-q-icon { width:20px; height:20px; position:relative; flex-shrink:0; transition:transform 0.4s; }
.faq-item.active .faq-q-icon { transform:rotate(45deg); }
.faq-q-icon::before,.faq-q-icon::after { content:''; position:absolute; background:var(--gray-400); border-radius:1px; }
.faq-q-icon::before { width:100%; height:2px; top:50%; transform:translateY(-50%); }
.faq-q-icon::after { width:2px; height:100%; left:50%; transform:translateX(-50%); }
.faq-a { max-height:0; overflow:hidden; transition: all 0.5s cubic-bezier(0.16,1,0.3,1); }
.faq-item.active .faq-a { max-height:500px; padding-bottom:24px; }
.faq-a p { font-family:var(--font-ui); font-size:15px; color:var(--gray-500); line-height:1.7; }

.footer { background:var(--primary); color:var(--white); padding:80px 0 40px; }
.footer-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:60px; margin-bottom:60px; }
.footer-brand h3 { font-family:var(--font-display); font-size:28px; margin-bottom:12px; }
.footer-brand h3 span { color:var(--accent); }
.footer-brand p { font-family:var(--font-ui); color:var(--gray-400); font-size:14px; line-height:1.7; max-width:300px; }
.footer h4 { font-family:var(--font-ui); font-size:12px; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent); margin-bottom:20px; }
.footer ul { list-style:none; }
.footer ul li { margin-bottom:12px; }
.footer ul a { font-family:var(--font-ui); font-size:14px; color:var(--gray-400); text-decoration:none; transition:color 0.3s; }
.footer ul a:hover { color:var(--white); }
.footer-bottom { border-top:1px solid rgba(255,255,255,0.06); padding-top:24px; display:flex; justify-content:space-between; align-items:center; font-family:var(--font-ui); font-size:13px; color:var(--gray-500); }
.footer-socials { display:flex; gap:16px; }
.footer-socials a { width:36px; height:36px; border:1px solid rgba(255,255,255,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--gray-400); text-decoration:none; transition:all 0.3s; font-size:14px; }
.footer-socials a:hover { border-color:var(--accent); color:var(--accent); }

.ai-chat-btn { position:fixed; bottom:32px; right:32px; z-index:900; width:56px; height:56px; border-radius:50%; background:var(--accent); border:none; cursor:pointer; box-shadow:0 8px 24px rgba(212,175,55,0.3); display:flex; align-items:center; justify-content:center; font-size:24px; transition: all 0.4s cubic-bezier(0.16,1,0.3,1); }
.ai-chat-btn:hover { transform:scale(1.1); box-shadow:0 12px 36px rgba(212,175,55,0.4); }
.ai-chat-panel { position:fixed; bottom:100px; right:32px; z-index:900; width:380px; max-height:520px; background:var(--white); border-radius:20px; box-shadow:0 32px 80px rgba(0,0,0,0.15); border:1px solid var(--gray-200); display:none; flex-direction:column; overflow:hidden; }
.ai-chat-panel.open { display:flex; }
.ai-chat-header { padding:20px 24px; background:var(--primary); color:var(--white); display:flex; justify-content:space-between; align-items:center; }
.ai-chat-header h3 { font-family:var(--font-display); font-size:16px; }
.ai-chat-header span { font-family:var(--font-ui); font-size:12px; color:var(--accent); }
.ai-chat-close { background:none; border:none; color:rgba(255,255,255,0.5); cursor:pointer; font-size:18px; }
.ai-chat-messages { flex:1; padding:20px; overflow-y:auto; display:flex; flex-direction:column; gap:12px; }
.ai-msg { max-width:85%; padding:12px 16px; border-radius:14px; font-family:var(--font-ui); font-size:14px; line-height:1.6; }
.ai-msg.bot { align-self:flex-start; background:var(--gray-100); color:var(--gray-600); border-bottom-left-radius:4px; }
.ai-msg.user { align-self:flex-end; background:var(--accent); color:var(--primary); border-bottom-right-radius:4px; }
.ai-msg .price { color:var(--accent-dark); font-weight:600; }
.ai-chat-input { display:flex; gap:8px; padding:12px 16px; border-top:1px solid var(--gray-200); }
.ai-chat-input input { flex:1; border:none; outline:none; font-family:var(--font-ui); font-size:14px; padding:8px 0; color:var(--primary); background:transparent; }
.ai-chat-input input::placeholder { color:var(--gray-400); }
.ai-chat-input button { background:var(--accent); border:none; color:var(--primary); width:36px; height:36px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:transform 0.2s; }
.ai-chat-input button:hover { transform:scale(1.05); }

.modal-overlay { position:fixed; inset:0; z-index:2000; background:rgba(17,17,17,0.8); backdrop-filter:blur(12px); display:none; align-items:center; justify-content:center; padding:24px; }
.modal-overlay.open { display:flex; }
.modal { background:var(--white); border-radius:20px; max-width:560px; width:100%; max-height:90vh; overflow-y:auto; padding:40px; position:relative; }
.modal-close { position:absolute; top:20px; right:20px; width:36px; height:36px; border-radius:50%; border:1px solid var(--gray-200); background:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray-400); transition:all 0.3s; }
.modal-close:hover { border-color:var(--accent); color:var(--accent-dark); }
.modal h2 { font-size:28px; margin-bottom:24px; }

.booking-steps { display:flex; flex-direction:column; gap:24px; }
.booking-step { }
.booking-step h4 { font-family:var(--font-ui); font-size:12px; text-transform:uppercase; letter-spacing:0.1em; color:var(--gray-400); margin-bottom:8px; }
.booking-step .step-title { font-family:var(--font-display); font-size:20px; margin-bottom:12px; }
.booking-options { display:flex; flex-wrap:wrap; gap:8px; }
.booking-option { padding:10px 20px; border:1px solid var(--gray-200); border-radius:100px; font-family:var(--font-ui); font-size:13px; cursor:pointer; transition:all 0.3s; background:none; color:var(--gray-600); }
.booking-option:hover { border-color:var(--accent); color:var(--accent-dark); }
.booking-option.selected { background:var(--accent); border-color:var(--accent); color:var(--primary); font-weight:500; }
.booking-field { width:100%; padding:12px 16px; border:1px solid var(--gray-200); border-radius:12px; font-family:var(--font-ui); font-size:14px; outline:none; transition:border-color 0.3s; color:var(--primary); background:var(--white); }
.booking-field:focus { border-color:var(--accent); }

.filter-bar { display:flex; gap:12px; flex-wrap:wrap; align-items:center; padding:16px 0; margin-bottom:40px; }
.filter-select { padding:10px 20px; border:1px solid var(--gray-200); border-radius:100px; font-family:var(--font-ui); font-size:13px; background:var(--white); cursor:pointer; outline:none; color:var(--gray-600); transition:border-color 0.3s; }
.filter-select:focus { border-color:var(--accent); }
.filter-select option { color:var(--primary); }

.parallax-slow { will-change:transform; }
.reveal { opacity:0; transform:translateY(40px); transition: all 1s cubic-bezier(0.16,1,0.3,1); }
.reveal.visible { opacity:1; transform:translateY(0); }
.reveal-delay-1 { transition-delay:0.1s; }
.reveal-delay-2 { transition-delay:0.2s; }
.reveal-delay-3 { transition-delay:0.3s; }
.reveal-delay-4 { transition-delay:0.4s; }

.gradient-text { background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 50%, var(--accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

.pricing-card { background:var(--white); border:1px solid var(--gray-200); border-radius:20px; padding:32px; transition:all 0.5s cubic-bezier(0.16,1,0.3,1); }
.pricing-card:hover { transform:translateY(-8px); box-shadow:0 32px 64px rgba(0,0,0,0.06); border-color:transparent; }
.pricing-card.featured { border-color:var(--accent); background:linear-gradient(135deg, rgba(212,175,55,0.03), transparent); }
.pricing-card h3 { font-size:24px; margin-bottom:4px; }
.pricing-card .price-range { font-family:var(--font-display); font-size:36px; color:var(--accent); font-weight:600; margin-bottom:16px; }
.pricing-card ul { list-style:none; margin-bottom:24px; }
.pricing-card ul li { padding:8px 0; font-family:var(--font-ui); font-size:14px; color:var(--gray-600); border-bottom:1px solid var(--gray-100); display:flex; align-items:center; gap:8px; }
.pricing-card ul li::before { content:'✓'; color:var(--accent); font-weight:600; }

.city-marquee { overflow:hidden; padding:40px 0; }
.city-track { display:flex; gap:16px; animation:scroll-cities 30s linear infinite; }
.city-chip { padding:12px 24px; border:1px solid var(--gray-200); border-radius:100px; font-family:var(--font-ui); font-size:14px; color:var(--gray-600); white-space:nowrap; transition:all 0.3s; cursor:pointer; text-decoration:none; display:inline-block; }
.city-chip:hover { border-color:var(--accent); color:var(--accent-dark); background:rgba(212,175,55,0.04); }
@keyframes scroll-cities { 0% { transform:translateX(0); } 100% { transform:translateX(-50%); } }

@media (max-width:1024px) {
  .cat-row { grid-template-columns:1fr; gap:40px; }
  .cat-row.reverse { direction:ltr; }
  .blog-grid { grid-template-columns:1fr 1fr; }
  .footer-grid { grid-template-columns:1fr 1fr; gap:40px; }
  .gallery-grid { grid-template-columns:1fr 1fr; }
}
@media (max-width:768px) {
  .nav { padding:16px 20px; }
  .nav.scrolled { padding:12px 20px; }
  .nav-links { display:none; }
  .nav-links.open { display:flex; flex-direction:column; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(17,17,17,0.98); backdrop-filter:blur(24px); padding:80px 40px; gap:24px; align-items:center; justify-content:center; }
  .nav-links.open a { font-size:24px; }
  .nav-mobile-btn { display:flex; }
  .nav-links .nav-cta { font-size:16px !important; padding:12px 32px; }
  .container { padding:0 20px; }
  .section { padding:80px 0; }
  .occasions-grid { grid-template-columns:1fr 1fr; gap:12px; }
  .blog-grid { grid-template-columns:1fr; }
  .footer-grid { grid-template-columns:1fr; gap:32px; }
  .gallery-grid { grid-template-columns:1fr; }
  .gallery-item.tall { grid-row:span 1; }
  .gallery-item.wide { grid-column:span 1; }
  .ai-chat-panel { width:calc(100vw - 32px); right:16px; bottom:90px; max-height:480px; }
  .testimonial-card { min-width:300px; }
  .booking-options { gap:6px; }
  .booking-option { padding:8px 16px; font-size:12px; }
  .pricing-card { padding:24px; }
}
@media (max-width:480px) {
  .occasions-grid { grid-template-columns:1fr; }
  .hero h1 { font-size:36px; }
  .hero-actions { flex-direction:column; align-items:center; }
  .btn { width:100%; justify-content:center; }
  .nav-logo { font-size:18px; }
}
</style>
</head>
<body>

<div class="loader" id="loader">
  <div class="loader-ring"></div>
  <div class="loader-text">Mahek Decorators</div>
</div>

<nav class="nav" id="nav">
  <a href="#" class="nav-logo">Mahek<span>.</span></a>
  <ul class="nav-links" id="navLinks">
    <li><a href="#occasions">Occasions</a></li>
    <li><a href="#categories">Packages</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="#reviews">Reviews</a></li>
    <li><a href="#blog">Blog</a></li>
    <li><a href="#contact" class="nav-cta">Book Now</a></li>
  </ul>
  <button class="nav-mobile-btn" id="navMobileBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<section class="hero" id="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-overlay"></div>
</section>

<section class="story-section" id="storytelling">
  <div class="story-pin" id="storyPin">
    <div class="story-sticky" id="storySticky">
      <div class="story-canvas" id="storyCanvas">
        <div class="story-balloon" id="storyBalloon">
          <div class="balloon-body"></div>
        </div>
        <div class="story-ribbon" id="storyRibbon1" style="top:30%;left:20%;"></div>
        <div class="story-ribbon" id="storyRibbon2" style="top:40%;right:25%;"></div>
        <div class="story-arch" id="storyArch1" style="top:25%;left:50%;transform:translateX(-50%);"></div>
        <div class="story-arch" id="storyArch2" style="bottom:30%;right:15%;"></div>
        <div class="story-deco" id="storyDeco1" style="top:40%;left:30%;"></div>
        <div class="story-deco" id="storyDeco2" style="bottom:35%;right:30%;"></div>
      </div>
      <div class="story-scenes">
        <div class="story-scene" id="scene1">
          <h3>A Single Balloon</h3>
          <p>Every great celebration begins with a single, elegant balloon — a promise of joy to come.</p>
        </div>
        <div class="story-scene" id="scene2">
          <h3>Ribbons Begin to Flow</h3>
          <p>The string transforms into graceful ribbons, dancing through the air with effortless beauty.</p>
        </div>
        <div class="story-scene" id="scene3">
          <h3>Arches Take Shape</h3>
          <p>Ribbons rise and curve into magnificent arches, framing moments that matter most.</p>
        </div>
        <div class="story-scene" id="scene4">
          <h3>Decorations Bloom</h3>
          <p>Arches blossom into elaborate decorations, filling spaces with warmth and wonder.</p>
        </div>
        <div class="story-scene" id="scene5">
          <h3>A Complete Celebration</h3>
          <p>From one balloon to an entire celebration — every detail crafted to perfection.</p>
        </div>
      </div>
      <div class="story-content" id="storyContent" style="opacity:0;">
        <h2>From a Single Balloon<br>to a <span class="gradient-text">Complete Celebration</span></h2>
        <p>Watch the magic unfold as we transform simple beginnings into extraordinary memories.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-light" id="occasions">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">Popular Occasions</div>
      <h2 class="section-title">Every Moment<br>Deserves Beauty</h2>
      <p class="section-subtitle">From intimate surprises to grand celebrations — we create magic for every occasion.</p>
    </div>
    <div class="occasions-grid" id="occasionsGrid">
      <div class="occ-card reveal reveal-delay-1">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=600&q=80" alt="Birthday Decoration" loading="lazy">
        <div class="occ-card-body"><h3>Birthday</h3><p>Vibrant and joyful birthday setups</p><div class="occ-card-price">From ₹999</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-2">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1519741497674-611481863552?w=600&q=80" alt="Anniversary Decoration" loading="lazy">
        <div class="occ-card-body"><h3>Anniversary</h3><p>Romantic celebrations of love</p><div class="occ-card-price">From ₹1,999</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-3">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1519974719765-e6559eac2575?w=600&q=80" alt="Baby Shower" loading="lazy">
        <div class="occ-card-body"><h3>Baby Shower</h3><p>Welcome the new arrival in style</p><div class="occ-card-price">From ₹2,499</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-1">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1558036117-15d82a90b9b1?w=600&q=80" alt="Wedding Decoration" loading="lazy">
        <div class="occ-card-body"><h3>Wedding</h3><p>Elegant wedding decor setups</p><div class="occ-card-price">From ₹15,000</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-2">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1469371670807-013ccf25f16a?w=600&q=80" alt="Engagement" loading="lazy">
        <div class="occ-card-body"><h3>Engagement</h3><p>Celebrate your commitment</p><div class="occ-card-price">From ₹5,000</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-3">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=600&q=80" alt="Proposal" loading="lazy">
        <div class="occ-card-body"><h3>Proposal</h3><p>Pop the question perfectly</p><div class="occ-card-price">From ₹2,499</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-1">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=600&q=80" alt="Corporate Event" loading="lazy">
        <div class="occ-card-body"><h3>Corporate Event</h3><p>Professional event setups</p><div class="occ-card-price">From ₹15,000</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-2">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1603214857302-0f3c76f7b27b?w=600&q=80" alt="House Warming" loading="lazy">
        <div class="occ-card-body"><h3>House Warming</h3><p>Warm your new home</p><div class="occ-card-price">From ₹1,499</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-3">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1558636508-e0db3814bd1d?w=600&q=80" alt="Haldi Decoration" loading="lazy">
        <div class="occ-card-body"><h3>Haldi</h3><p>Vibrant pre-wedding ceremonies</p><div class="occ-card-price">From ₹4,999</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-1">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1464349153735-7db50ed83c84?w=600&q=80" alt="Kids Party" loading="lazy">
        <div class="occ-card-body"><h3>Kids Theme Party</h3><p>Magical themes for little ones</p><div class="occ-card-price">From ₹1,999</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-2">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1530023367847-a683933f4172?w=600&q=80" alt="Festival Decoration" loading="lazy">
        <div class="occ-card-body"><h3>Festival Decoration</h3><p>Celebrate festivals in style</p><div class="occ-card-price">From ₹2,999</div></div>
      </div>
      <div class="occ-card reveal reveal-delay-3">
        <img class="occ-card-img" src="https://images.unsplash.com/photo-1481162854517-d9e353af867d?w=600&q=80" alt="Bride to Be" loading="lazy">
        <div class="occ-card-body"><h3>Bride To Be</h3><p>Special pre-wedding celebration</p><div class="occ-card-price">From ₹3,999</div></div>
      </div>
    </div>
  </div>
</section>

<section class="section section-white" id="categories">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">Premium Categories</div>
      <h2 class="section-title">Every Scale,<br>Every Occasion</h2>
      <p class="section-subtitle">From intimate room setups to grand luxury events — find the perfect package for your celebration.</p>
    </div>

    <div class="filter-bar reveal" id="filterBar">
      <select class="filter-select" id="filterCategory">
        <option value="all">All Categories</option>
        <option value="small">Small Scale</option>
        <option value="medium">Medium Scale</option>
        <option value="large">Large Scale</option>
        <option value="luxury">Luxury Events</option>
      </select>
      <select class="filter-select" id="filterBudget">
        <option value="all">Any Budget</option>
        <option value="999-4999">₹999 - ₹4,999</option>
        <option value="5000-15000">₹5,000 - ₹15,000</option>
        <option value="15000-50000">₹15,000 - ₹50,000</option>
        <option value="50000-500000">₹50,000+</option>
      </select>
      <select class="filter-select" id="filterOccasion">
        <option value="all">Any Occasion</option>
        <option value="birthday">Birthday</option>
        <option value="wedding">Wedding</option>
        <option value="anniversary">Anniversary</option>
        <option value="proposal">Proposal</option>
        <option value="corporate">Corporate</option>
      </select>
    </div>

    <div class="categories" id="categoriesContainer">
      <div class="cat-row reveal" data-category="small" data-budget="999-4999">
        <div class="cat-info">
          <div class="cat-label">Small Scale</div>
          <h2 class="cat-title">Intimate Celebrations</h2>
          <div class="cat-price">₹999 – ₹4,999</div>
          <p class="cat-desc">Perfect for intimate surprises and close-knit celebrations. Our small-scale setups bring charm and elegance to any cozy space.</p>
          <ul class="cat-list">
            <li>Room Decoration</li>
            <li>Surprise Decoration</li>
            <li>Cake Table Setup</li>
            <li>Kids Corner</li>
            <li>Simple Birthday</li>
          </ul>
        </div>
        <div class="cat-visual">
          <div class="cat-badge">Starting ₹999</div>
          <div class="cat-visual-img">
            <img src="https://images.unsplash.com/photo-1578911373434-0cb395d2cbfb?w=800&q=80" alt="Small Scale Decoration" loading="lazy">
          </div>
        </div>
      </div>

      <div class="cat-row reverse reveal" data-category="medium" data-budget="5000-15000">
        <div class="cat-info">
          <div class="cat-label">Medium Scale</div>
          <h2 class="cat-title">Special Moments</h2>
          <div class="cat-price">₹5,000 – ₹15,000</div>
          <p class="cat-desc">Designed for celebrations that call for something extra special. These setups create memorable experiences without overwhelming the space.</p>
          <ul class="cat-list">
            <li>Baby Shower</li>
            <li>Anniversary Setup</li>
            <li>Terrace Decoration</li>
            <li>Bride to Be Setup</li>
            <li>Proposal Setup</li>
          </ul>
        </div>
        <div class="cat-visual">
          <div class="cat-badge">Starting ₹5,000</div>
          <div class="cat-visual-img">
            <img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=800&q=80" alt="Medium Scale Decoration" loading="lazy">
          </div>
        </div>
      </div>

      <div class="cat-row reveal" data-category="large" data-budget="15000-50000">
        <div class="cat-info">
          <div class="cat-label">Large Scale</div>
          <h2 class="cat-title">Grand Celebrations</h2>
          <div class="cat-price">₹15,000 – ₹50,000</div>
          <p class="cat-desc">For events that make a statement. Our large-scale creations transform venues into breathtaking experiences that guests will remember.</p>
          <ul class="cat-list">
            <li>Wedding Decoration</li>
            <li>Engagement Setup</li>
            <li>Haldi Ceremony</li>
            <li>Corporate Setup</li>
            <li>Stage Decoration</li>
          </ul>
        </div>
        <div class="cat-visual">
          <div class="cat-badge">Starting ₹15,000</div>
          <div class="cat-visual-img">
            <img src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=800&q=80" alt="Large Scale Decoration" loading="lazy">
          </div>
        </div>
      </div>

      <div class="cat-row reverse reveal" data-category="luxury" data-budget="50000-500000">
        <div class="cat-info">
          <div class="cat-label">Luxury Events</div>
          <h2 class="cat-title">Extraordinary Experiences</h2>
          <div class="cat-price">₹50,000 – ₹5,00,000+</div>
          <p class="cat-desc">Where opulence meets artistry. Our luxury division creates show-stopping environments for the most discerning clients and prestigious events.</p>
          <ul class="cat-list">
            <li>Luxury Weddings</li>
            <li>Destination Setups</li>
            <li>Premium Stage Decor</li>
            <li>Celebrity Events</li>
            <li>Corporate Conferences</li>
          </ul>
        </div>
        <div class="cat-visual">
          <div class="cat-badge">Luxury</div>
          <div class="cat-visual-img">
            <img src="https://images.unsplash.com/photo-1510076857177-7470076d4098?w=800&q=80" alt="Luxury Event Decoration" loading="lazy">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="city-marquee section-light">
  <div class="city-track" id="cityTrack">
    <a class="city-chip">Pune</a><a class="city-chip">Pimpri</a><a class="city-chip">Hinjewadi</a><a class="city-chip">Wakad</a><a class="city-chip">Baner</a><a class="city-chip">Kharadi</a><a class="city-chip">Hadapsar</a><a class="city-chip">Talegaon</a><a class="city-chip">Lonavala</a><a class="city-chip">Satara</a><a class="city-chip">Ahmednagar</a><a class="city-chip">Baramati</a><a class="city-chip">Chakan</a>
    <a class="city-chip">Pune</a><a class="city-chip">Pimpri</a><a class="city-chip">Hinjewadi</a><a class="city-chip">Wakad</a><a class="city-chip">Baner</a><a class="city-chip">Kharadi</a><a class="city-chip">Hadapsar</a><a class="city-chip">Talegaon</a><a class="city-chip">Lonavala</a><a class="city-chip">Satara</a><a class="city-chip">Ahmednagar</a><a class="city-chip">Baramati</a><a class="city-chip">Chakan</a>
  </div>
</div>

<section class="section section-light" id="gallery">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">Gallery</div>
      <h2 class="section-title">Our Masterpieces</h2>
      <p class="section-subtitle">Each decoration tells a story. Browse through our recent creations.</p>
    </div>
    <div class="gallery-grid">
      <div class="gallery-item wide reveal reveal-delay-1">
        <img src="https://images.unsplash.com/photo-1558036117-15d82a90b9b1?w=800&q=80" alt="Gallery" loading="lazy">
        <div class="gallery-overlay"><span>Wedding Reception Setup</span></div>
      </div>
      <div class="gallery-item tall reveal reveal-delay-2">
        <img src="https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=600&q=80" alt="Gallery" loading="lazy">
        <div class="gallery-overlay"><span>Birthday Celebration</span></div>
      </div>
      <div class="gallery-item reveal reveal-delay-3">
        <img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=600&q=80" alt="Gallery" loading="lazy">
        <div class="gallery-overlay"><span>Proposal Setup</span></div>
      </div>
