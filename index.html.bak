<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.28/bundled/lenis.min.js"></script>
<script>
// ===== LENIS SMOOTH SCROLL =====
const lenis = new Lenis({
  duration: 1.4,
  easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  orientation: 'vertical',
  smoothWheel: true,
  wheelMultiplier: 0.8,
  touchMultiplier: 1.2,
});
function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
requestAnimationFrame(raf);

lenis.on('scroll', ScrollTrigger.update);
gsap.ticker.add((time) => lenis.raf(time * 1000));
gsap.ticker.lagSmoothing(0);

// ===== LOADING SCREEN =====
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('loader').classList.add('hidden');
  }, 1500);
});

// ===== NAVIGATION =====
const nav = document.getElementById('nav');
const navMobileBtn = document.getElementById('navMobileBtn');
const navLinks = document.getElementById('navLinks');

navMobileBtn.addEventListener('click', () => {
  navMobileBtn.classList.toggle('active');
  navLinks.classList.toggle('open');
});

navLinks.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    navMobileBtn.classList.remove('active');
    navLinks.classList.remove('open');
  });
});

lenis.on('scroll', (e) => {
  if (e.velocity > 0.5) {
    nav.classList.add('scrolled');
  } else if (window.scrollY > 80) {
    nav.classList.add('scrolled');
  } else {
    nav.classList.remove('scrolled');
  }
});

// ===== SCROLL STORYTELLING (GSAP) =====
gsap.registerPlugin(ScrollTrigger);

const storyPin = document.getElementById('storyPin');
const storyBalloon = document.getElementById('storyBalloon');
const storyRibbon1 = document.getElementById('storyRibbon1');
const storyRibbon2 = document.getElementById('storyRibbon2');
const storyArch1 = document.getElementById('storyArch1');
const storyArch2 = document.getElementById('storyArch2');
const storyDeco1 = document.getElementById('storyDeco1');
const storyDeco2 = document.getElementById('storyDeco2');
const scenes = [
  document.getElementById('scene1'),
  document.getElementById('scene2'),
  document.getElementById('scene3'),
  document.getElementById('scene4'),
  document.getElementById('scene5'),
];

ScrollTrigger.create({
  trigger: storyPin,
  start: 'top top',
  end: 'bottom bottom',
  pin: true,
  pinSpacing: false,
});

const tl = gsap.timeline({
  scrollTrigger: {
    trigger: storyPin,
    start: 'top top',
    end: '+=300%',
    scrub: 1.2,
    invalidateOnRefresh: true,
  }
});

// Scene 1: Balloon rises and floats
tl.fromTo(storyBalloon, { opacity: 0, scale: 0.5, y: 100 }, { opacity: 1, scale: 1, y: -50, duration: 1, ease: 'power2.out' })
  .to(storyBalloon, { y: -80, duration: 0.5, ease: 'none' }, '+=0.3');

// Scene 2: Ribbons appear
tl.to(storyRibbon1, { opacity: 1, scaleX: 1, width: 200, duration: 0.6, ease: 'back.out(1.7)' }, '+=0.2')
  .to(storyRibbon2, { opacity: 1, scaleX: 1, width: 180, duration: 0.6, ease: 'back.out(1.7)' }, '-=0.3');

// Scene 3: Arches form
tl.to(storyArch1, { opacity: 1, scale: 1, duration: 0.8, ease: 'power2.out' }, '+=0.3')
  .to(storyArch2, { opacity: 1, scale: 1, duration: 0.8, ease: 'power2.out' }, '-=0.4')
  .to(storyRibbon1, { opacity: 0, duration: 0.3 }, '-=0.3')
  .to(storyRibbon2, { opacity: 0, duration: 0.3 }, '-=0.3');

// Scene 4: Decorations bloom
tl.to(storyDeco1, { opacity: 1, scale: 3, duration: 0.8, ease: 'power2.out' }, '+=0.3')
  .to(storyDeco2, { opacity: 1, scale: 3, duration: 0.8, ease: 'power2.out' }, '-=0.4')
  .to(storyArch1, { opacity: 0.3, duration: 0.3 }, '-=0.3')
  .to(storyArch2, { opacity: 0.3, duration: 0.3 }, '-=0.3');

// Scene 5: Complete celebration
tl.to(storyDeco1, { scale: 5, opacity: 0.2, duration: 0.6 }, '+=0.2')
  .to(storyDeco2, { scale: 5, opacity: 0.2, duration: 0.6 }, '-=0.5')
  .to(storyBalloon, { opacity: 0, duration: 0.4 }, '-=0.3')
  .to('#storyContent', { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' }, '-=0.2');

// Text scenes
scenes.forEach((scene, i) => {
  const start = i / scenes.length;
  const end = (i + 1) / scenes.length;
  gsap.fromTo(scene,
    { opacity: 0, y: 20 },
    {
      opacity: 1, y: 0, duration: 0.01,
      scrollTrigger: {
        trigger: storyPin,
        start: start * 100 + '%',
        end: end * 100 + '%',
        scrub: 0.5,
      }
    }
  );
  gsap.to(scene, {
    opacity: 0, y: -20, duration: 0.01,
    scrollTrigger: {
      trigger: storyPin,
      start: (end - 0.1) * 100 + '%',
      end: end * 100 + '%',
      scrub: 0.5,
    }
  });
});

// ===== REVEAL ANIMATIONS =====
const revealElements = document.querySelectorAll('.reveal');
revealElements.forEach((el) => {
  ScrollTrigger.create({
    trigger: el,
    start: 'top 90%',
    onEnter: () => el.classList.add('visible'),
    once: true,
  });
});

// ===== GALLERY ITEM PARALLAX =====
document.querySelectorAll('.gallery-item img, .cat-visual-img img').forEach(img => {
  gsap.fromTo(img, { y: -20 }, {
    y: 20,
    ease: 'none',
    scrollTrigger: {
      trigger: img.closest('.gallery-item') || img.closest('.cat-visual'),
      start: 'top bottom',
      end: 'bottom top',
      scrub: 1,
    }
  });
});

// ===== FILTER SYSTEM =====
function filterCategories() {
  const cat = document.getElementById('filterCategory').value;
  const budget = document.getElementById('filterBudget').value;
  const occasion = document.getElementById('filterOccasion').value;
  document.querySelectorAll('.cat-row').forEach(row => {
    const c = row.dataset.category;
    const b = row.dataset.budget;
    let show = true;
    if (cat !== 'all' && c !== cat) show = false;
    if (budget !== 'all' && b !== budget) show = false;
    gsap.to(row, { opacity: show ? 1 : 0.2, scale: show ? 1 : 0.95, duration: 0.5, ease: 'power2.out' });
    row.style.pointerEvents = show ? 'auto' : 'none';
  });
}

document.getElementById('filterCategory').addEventListener('change', filterCategories);
document.getElementById('filterBudget').addEventListener('change', filterCategories);
document.getElementById('filterOccasion').addEventListener('change', filterCategories);

// ===== FAQ ACCORDION =====
document.querySelectorAll('.faq-q').forEach(q => {
  q.addEventListener('click', () => {
    const item = q.closest('.faq-item');
    const isActive = item.classList.contains('active');
    document.querySelectorAll('.faq-item.active').forEach(i => i.classList.remove('active'));
    if (!isActive) item.classList.add('active');
  });
});

// ===== BOOKING MODAL =====
function openBooking() {
  document.getElementById('bookingModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeBooking() {
  document.getElementById('bookingModal').classList.remove('open');
  document.body.style.overflow = '';
}
function selectBooking(el) {
  const parent = el.parentElement;
  parent.querySelectorAll('.booking-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}
function submitBooking() {
  closeBooking();
  setTimeout(() => {
    document.getElementById('successModal').classList.add('open');
  }, 300);
}

document.getElementById('bookingModal').addEventListener('click', (e) => {
  if (e.target === document.getElementById('bookingModal')) closeBooking();
});

// ===== AI CHAT =====
let chatOpen = false;
function toggleChat() {
  chatOpen = !chatOpen;
  document.getElementById('aiChatPanel').classList.toggle('open', chatOpen);
}

const aiResponses = [
  { keywords: ['birthday', 'bday'], response: 'For birthday decorations under ₹5,000, I recommend our Essential Birthday Package starting at ₹999! Includes room decoration, cake table setup, and a beautiful balloon arch. For a grander celebration, our Celebration Package at ₹5,000-₹15,000 includes themed decor and premium balloons.' },
  { keywords: ['anniversary', 'anniversary'], response: 'Our Romantic Anniversary Packages start at ₹1,999! For an intimate setup, try our Small Scale package with rose petals, balloons, and LED candles. The premium package at ₹5,000+ includes a photo wall and personalized name board.' },
  { keywords: ['proposal', 'propose'], response: 'Planning a proposal? Our Proposal Setup starting at ₹2,499 includes a dreamy balloon arch, rose petals pathway, LED lights, and a photo frame. Add a neon sign with your message for ₹999 more!' },
  { keywords: ['wedding', 'marriage'], response: 'For wedding decorations, we offer three tiers: Essential Wedding (₹15,000-₹25,000), Premium Wedding (₹25,000-₹50,000), and Luxury Wedding (₹50,000+). Each includes mandap decoration, entrance arch, stage setup, and more.' },
  { keywords: ['baby shower'], response: 'Baby shower decorations start at ₹2,499! Our packages include pastel balloon arches, themed centerpieces, cake table setup, and decorative banners. The premium package includes a photo backdrop and gift table.' },
  { keywords: ['corporate', 'office', 'business'], response: 'Corporate event decoration starts at ₹15,000. We offer stage decoration, entrance branding, backdrop setup, and themed corporate environments. Our team can handle events for 50-500+ attendees.' },
  { keywords: ['small', 'budget', 'cheap', 'low'], response: 'Looking for budget-friendly options? Our Small Scale packages start from just ₹999! Perfect for room decoration, surprise setups, and intimate celebrations. You get premium quality at an affordable price.' },
  { keywords: ['luxury', 'premium', 'high end', 'expensive'], response: 'Our Luxury Events division handles premium celebrations from ₹50,000 to ₹5,00,000+. Includes imported balloons, custom themes, dedicated designer, and full-service coordination. Perfect for luxury weddings and high-profile events.' },
  { keywords: ['hallo', 'diwali', 'festival', 'holi'], response: 'Festival decorations start at ₹2,999! We create stunning festive setups for Diwali, Holi, Ganesh Chaturthi, and more. Includes themed balloons, floral arrangements, and traditional decor elements.' },
];

function sendAiMessage() {
  const input = document.getElementById('aiInput');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';

  const messages = document.getElementById('aiMessages');
  const userMsg = document.createElement('div');
  userMsg.className = 'ai-msg user';
  userMsg.textContent = text;
  messages.appendChild(userMsg);
  messages.scrollTop = messages.scrollHeight;

  setTimeout(() => {
    let response = "That sounds wonderful! I'd recommend browsing our packages above — we have options for every budget and occasion. Could you tell me more about your specific needs?";
    const lower = text.toLowerCase();
    for (const item of aiResponses) {
      if (item.keywords.some(k => lower.includes(k))) {
        response = item.response;
        break;
      }
    }
    if (lower.includes('500') || lower.includes('1000') || lower.includes('2000') || lower.includes('3000') || lower.includes('4000')) {
      response = "Great budget! Our Small Scale decorations (₹999-₹4,999) would be perfect for you. We have options for birthdays, anniversaries, and surprise decorations within this range. Would you like to see specific options?";
    }
    if (lower.includes('5000') || lower.includes('10000') || lower.includes('15000')) {
      response = "Excellent! Our Medium Scale packages (₹5,000-₹15,000) are our most popular. Great for baby showers, proposals, and anniversary setups. Premium quality with elegant designs. Would you like to book a consultation?";
    }
    if (lower.includes('book') || lower.includes('appointment') || lower.includes('contact')) {
      response = "I'd love to help you book! You can click the 'Book Now' button above or call us directly at +91 98765 43210. Our team will help you create the perfect celebration! 🎈";
    }
    const botMsg = document.createElement('div');
    botMsg.className = 'ai-msg bot';
    botMsg.innerHTML = response.replace(/\n/g, '<br>');
    messages.appendChild(botMsg);
    messages.scrollTop = messages.scrollHeight;
  }, 800);
}

// ===== SMOOTH ANCHOR LINKS =====
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', (e) => {
    const href = a.getAttribute('href');
    if (href === '#') return;
    e.preventDefault();
    const target = document.querySelector(href);
    if (target) {
      lenis.scrollTo(target, { offset: -80, duration: 1.4 });
    }
  });
});

// ===== COUNTER ANIMATION =====
let counted = false;
ScrollTrigger.create({
  trigger: '.footer',
  start: 'top 90%',
  onEnter: () => {
    if (!counted) {
      counted = true;
      // Simple counter animation for stats could go here
    }
  },
  once: true,
});

console.log('%cMAHEK DECORATOR', 'font-size:24px;font-weight:bold;color:#D4AF37;');
console.log('%cPremium Balloon Decorations — Pune', 'font-size:14px;color:#6B6B68;');
</script>

<script type="module">
import * as THREE from 'three';
import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';
import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

const canvas = document.getElementById('hero-canvas');
const hero = document.getElementById('hero');
if (!canvas || !hero) throw new Error('Hero elements not found');

// === SCENE ===
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x050505);
scene.fog = new THREE.FogExp2(0x050505, 0.025);

const camera = new THREE.PerspectiveCamera(40, window.innerWidth / window.innerHeight, 0.1, 1000);
camera.position.set(0, 0, 7);

const renderer = new THREE.WebGLRenderer({
  canvas,
  antialias: true,
  powerPreference: 'high-performance',
});
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

// Post-processing
const composer = new EffectComposer(renderer);
composer.addPass(new RenderPass(scene, camera));
const bloomPass = new UnrealBloomPass(
  new THREE.Vector2(window.innerWidth, window.innerHeight), 0.35, 0.6, 0.05
);
composer.addPass(bloomPass);
composer.addPass(new OutputPass());

// Environment map
const pmrem = new THREE.PMREMGenerator(renderer);
scene.environment = pmrem.fromScene(new RoomEnvironment(renderer), 0.04).texture;
pmrem.dispose();

// Lights
const ambient = new THREE.AmbientLight(0x222244, 0.5);
scene.add(ambient);
const key = new THREE.DirectionalLight(0x7a1fff, 1.8);
key.position.set(2, 3, 4);
scene.add(key);
const fill = new THREE.DirectionalLight(0xd4af37, 0.6);
fill.position.set(-3, 1, -2);
scene.add(fill);
const rim = new THREE.DirectionalLight(0x7a1fff, 0.8);
rim.position.set(-1, -2, -3);
scene.add(rim);

// === BALLOON GEOMETRY ===
function makeBalloonGeo() {
  const pts = [];
  const seg = 48;
  for (let i = 0; i <= seg; i++) {
    const t = i / seg;
    const a = t * Math.PI;
    const r = Math.sin(a) * (0.7 + Math.sin(a * 2) * 0.12);
    const y = Math.cos(a) * 0.95 - 0.15;
    const pinch = i > seg * 0.88 ? 1 - (i - seg * 0.88) / (seg * 0.12) * 0.5 : 1;
    pts.push(new THREE.Vector2(r * pinch, y));
  }
  return new THREE.LatheGeometry(pts, 48);
}
const bGeo = makeBalloonGeo();

// Outer glass balloon
const glassMat = new THREE.MeshPhysicalMaterial({
  color: 0xffffff,
  metalness: 0.0,
  roughness: 0.03,
  transparent: true,
  opacity: 0.3,
  clearcoat: 1.0,
  clearcoatRoughness: 0.05,
  transmission: 0.6,
  thickness: 2.0,
  envMapIntensity: 2.5,
  side: THREE.DoubleSide,
  depthWrite: false,
});
const balloon = new THREE.Mesh(bGeo, glassMat);
balloon.position.y = 0.15;

// Inner purple energy
const innerMat = new THREE.MeshPhysicalMaterial({
  color: 0x7a1fff,
  emissive: 0x7a1fff,
  emissiveIntensity: 0.5,
  transparent: true,
  opacity: 0.3,
  roughness: 0.2,
  metalness: 0.0,
  depthWrite: false,
});
const innerBalloon = new THREE.Mesh(bGeo.clone(), innerMat);
innerBalloon.scale.set(0.72, 0.72, 0.72);

// Gold edges
const goldEdges = new THREE.LineSegments(
  new THREE.EdgesGeometry(bGeo),
  new THREE.LineBasicMaterial({ color: 0xd4af37, transparent: true, opacity: 0.2 })
);

// Knot
const knotMat = new THREE.MeshPhysicalMaterial({ color: 0xd4af37, metalness: 0.9, roughness: 0.15 });
const knot = new THREE.Mesh(new THREE.SphereGeometry(0.07, 8, 8), knotMat);
knot.position.set(0, -0.88, 0);
balloon.add(knot);

innerBalloon.renderOrder = 1;
balloon.renderOrder = 2;
goldEdges.renderOrder = 3;

const balloonGroup = new THREE.Group();
balloonGroup.add(balloon);
balloonGroup.add(innerBalloon);
balloonGroup.add(goldEdges);
scene.add(balloonGroup);

// === TYPOGRAPHY ===
function makeTypography() {
  const c = document.createElement('canvas');
  c.width = 2048; c.height = 1024;
  const ctx = c.getContext('2d');
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  const font = 'bold 140px "Clash Display", system-ui, sans-serif';

  ctx.shadowColor = 'rgba(212,175,55,0.3)';
  ctx.shadowBlur = 80;
  ctx.font = font;
  ctx.fillStyle = 'rgba(212,175,55,0.07)';
  ctx.filter = 'blur(10px)';
  ctx.fillText('MAHEK DECORATOR', c.width/2, c.height/2);

  ctx.shadowColor = 'rgba(122,31,255,0.2)';
  ctx.shadowBlur = 60;
  ctx.filter = 'blur(5px)';
  ctx.fillStyle = 'rgba(122,31,255,0.05)';
  ctx.fillText('MAHEK DECORATOR', c.width/2, c.height/2 + 1);

  ctx.shadowColor = 'transparent';
  ctx.shadowBlur = 0;
  ctx.filter = 'none';
  ctx.fillStyle = 'rgba(255,255,255,0.03)';
  ctx.fillText('MAHEK DECORATOR', c.width/2, c.height/2);

  ctx.strokeStyle = 'rgba(212,175,55,0.12)';
  ctx.lineWidth = 1.5;
  ctx.strokeText('MAHEK DECORATOR', c.width/2, c.height/2);

  const tex = new THREE.CanvasTexture(c);
  tex.needsUpdate = true;
  const mesh = new THREE.Mesh(
    new THREE.PlaneGeometry(18, 9),
    new THREE.MeshBasicMaterial({
      map: tex, transparent: true, opacity: 0.4,
      depthWrite: false, side: THREE.DoubleSide,
      blending: THREE.AdditiveBlending,
    })
  );
  mesh.position.set(0, 0.15, -4.5);
  return mesh;
}
const typography = makeTypography();
scene.add(typography);

// === PARTICLES ===
function makeParticles(count) {
  const pos = new Float32Array(count * 3);
  const col = new Float32Array(count * 3);
  const sizes = new Float32Array(count);
  const pc = new THREE.Color(0x7a1fff), gc = new THREE.Color(0xd4af37), wc = new THREE.Color(0xffffff);
  for (let i = 0; i < count; i++) {
    pos[i*3] = (Math.random() - 0.5) * 28;
    pos[i*3+1] = (Math.random() - 0.5) * 18;
    pos[i*3+2] = (Math.random() - 0.5) * 20 - 3;
    const c = Math.random() < 0.5 ? wc : Math.random() < 0.6 ? pc : gc;
    col[i*3] = c.r; col[i*3+1] = c.g; col[i*3+2] = c.b;
    sizes[i] = 0.003 + Math.random() * 0.02;
  }
  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  geo.setAttribute('color', new THREE.BufferAttribute(col, 3));
  geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
  const mat = new THREE.PointsMaterial({
    size: 0.04, vertexColors: true, transparent: true, opacity: 0.4,
    blending: THREE.AdditiveBlending, depthWrite: false, sizeAttenuation: true,
  });
  return new THREE.Points(geo, mat);
}
const particles = makeParticles(3000);
scene.add(particles);

// === GOLD RIBBONS ===
const ribbonGroup = new THREE.Group();
scene.add(ribbonGroup);
function makeRibbon() {
  const pts = [
    [0,-0.8,0],[0.5,-0.3,0.3],[0.8,0.2,0.5],[0.5,0.8,0.3],[0,1.2,0],
    [-0.5,0.8,-0.3],[-0.8,0.2,-0.5],[-0.5,-0.3,-0.3],[0,-0.8,0]
  ].map(p => new THREE.Vector3(p[0], p[1], p[2]));
  const curve = new THREE.CatmullRomCurve3(pts);
  const mat = new THREE.MeshPhysicalMaterial({
    color: 0xd4af37, emissive: 0xd4af37, emissiveIntensity: 0.3,
    metalness: 0.8, roughness: 0.15, transparent: true, opacity: 0,
    clearcoat: 0.2,
  });
  return new THREE.Mesh(new THREE.TubeGeometry(curve, 48, 0.015, 6, false), mat);
}
for (let i = 0; i < 3; i++) {
  const r = makeRibbon();
  r.rotation.y = (i / 3) * Math.PI * 2;
  ribbonGroup.add(r);
}

// === CLUSTER BALLOONS ===
const clusterGroup = new THREE.Group();
scene.add(clusterGroup);
const cPositions = [[-1.4,1.0,0.5],[1.4,0.9,-0.3],[-1.0,-0.8,0.7],[1.0,-0.7,-0.5],[0,1.6,-0.2]];
const cColors = [0xd4af37,0x9b59b6,0x8e44ad,0xd4af37,0x7a1fff];
cPositions.forEach((pos, i) => {
  const m = new THREE.Mesh(bGeo.clone(), new THREE.MeshPhysicalMaterial({
    color: cColors[i], metalness: 0.1, roughness: 0.15,
    transparent: true, opacity: 0, clearcoat: 0.5, envMapIntensity: 1.0,
  }));
  m.position.set(pos[0], pos[1], pos[2]);
  m.scale.set(0.01, 0.01, 0.01);
  clusterGroup.add(m);
});

// === DECORATIVE LIGHTS ===
const decoGroup = new THREE.Group();
scene.add(decoGroup);
for (let i = 0; i < 30; i++) {
  const a = (i / 30) * Math.PI * 2;
  const r = 2.0 + Math.random() * 0.8;
  const h = (Math.random() - 0.5) * 3.0;
  const m = new THREE.Mesh(
    new THREE.SphereGeometry(0.025, 6, 6),
    new THREE.MeshBasicMaterial({ color: 0xd4af37, transparent: true, opacity: 0, blending: THREE.AdditiveBlending })
  );
  m.position.set(Math.sin(a)*r, h, Math.cos(a)*r);
  m.userData = { speed: 0.3 + Math.random()*0.7, offset: Math.random()*6, baseY: h };
  decoGroup.add(m);
}

// === VOLUMETRIC LIGHT RAYS ===
const rayGroup = new THREE.Group();
scene.add(rayGroup);
for (let i = 0; i < 10; i++) {
  const a = (i / 10) * Math.PI * 2;
  const m = new THREE.Mesh(
    new THREE.CylinderGeometry(0.004, 0.035, 4, 6, 1, true),
    new THREE.MeshBasicMaterial({
      color: 0xd4af37, transparent: true, opacity: 0,
      blending: THREE.AdditiveBlending, depthWrite: false, side: THREE.DoubleSide,
    })
  );
  m.position.set(Math.sin(a)*1.8, -0.3, Math.cos(a)*1.8);
  m.rotation.x = Math.PI / 2 - 0.3;
  m.rotation.z = a;
  rayGroup.add(m);
}

// === FLORAL ACCENTS ===
const floralGroup = new THREE.Group();
scene.add(floralGroup);
[
  [-1.8,0.6,1.2],[1.8,-0.5,-1.0],[-1.4,-1.0,1.3],[1.5,1.0,-1.2],[0,-0.6,1.6]
].forEach(pos => {
  const m = new THREE.Mesh(
    new THREE.SphereGeometry(0.04, 6, 6),
    new THREE.MeshPhysicalMaterial({
      color: 0xd4af37, emissive: 0xd4af37, emissiveIntensity: 0.3,
      metalness: 0.4, roughness: 0.3, transparent: true, opacity: 0,
    })
  );
  m.position.set(pos[0], pos[1], pos[2]);
  floralGroup.add(m);
});

// === SCROLL TRACKING ===
const ST = window.ScrollTrigger;
let progress = 0;
if (ST) {
  ST.create({
    trigger: '#hero', start: 'top top', end: '+=100%',
    scrub: 1.5, pin: true, pinSpacing: true,
    onUpdate: (self) => { progress = self.progress; },
  });
}

// === MOUSE ===
let mx = 0, my = 0, tx = 0, ty = 0;
document.addEventListener('mousemove', (e) => {
  tx = (e.clientX / window.innerWidth - 0.5) * 2;
  ty = (e.clientY / window.innerHeight - 0.5) * 2;
});

// === RESIZE ===
window.addEventListener('resize', () => {
  const w = window.innerWidth, h = window.innerHeight;
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
  renderer.setSize(w, h);
  composer.setSize(w, h);
});

// === HOVER GLOW ===
let hoverActive = false;
canvas.addEventListener('mouseenter', () => { hoverActive = true; });
canvas.addEventListener('mouseleave', () => { hoverActive = false; });

// === ANIMATION LOOP ===
const clock = new THREE.Clock();
const pPositions = particles.geometry.attributes.position.array;
const pCount = pPositions.length / 3;

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();
  const p = Math.min(Math.max(progress, 0), 1);

  // Smooth mouse
  mx += (tx - mx) * 0.05;
  my += (ty - my) * 0.05;

  // Hover
  const hoverIntensity = hoverActive ? 1 + Math.sin(t * 2) * 0.1 : 0;

  // Phase calculations
  const ph0 = Math.min(1, p / 0.2);
  const ph1 = Math.max(0, Math.min(1, (p - 0.2) / 0.2));
  const ph2 = Math.max(0, Math.min(1, (p - 0.4) / 0.2));
  const ph3 = Math.max(0, Math.min(1, (p - 0.6) / 0.2));
  const ph4 = Math.max(0, Math.min(1, (p - 0.8) / 0.2));

  // Camera
  const cz = 7 - p * 2.5 + ph4 * 1.2;
  const cy = ph2 * 1.2 - ph4 * 0.4;
  const cRot = ph1 * 0.5 - ph4 * 0.2;
  camera.position.x = Math.sin(cRot) * 2.5 + mx * 0.35;
  camera.position.y = cy - my * 0.3;
  camera.position.z = cz;
  camera.lookAt(0, 0.15 + ph2 * 0.4, 0);

  // Balloon rotation
  const br = p * 0.4 + mx * 0.1;
  balloonGroup.rotation.y = br;
  balloon.rotation.x = Math.sin(t * 0.4) * 0.02;
  innerBalloon.rotation.x = balloon.rotation.x;
  goldEdges.rotation.x = balloon.rotation.x;

  // Balloon morph (phase2+)
  const ms = 1 + ph2 * 0.1 + ph3 * 0.08;
  balloon.scale.set(ms, ms + ph2 * 0.15, ms);
  const innerMs = 0.72 * ms;
  innerBalloon.scale.set(innerMs, innerMs + ph2 * 0.11, innerMs);

  // Energy pulsing
  const pulse = 1 + Math.sin(t * 1.5) * 0.04;
  const eI = (0.5 + ph0 * 1.0 + hoverIntensity * 0.3) * (0.8 + Math.sin(t * 1.5) * 0.2);
  innerBalloon.material.emissiveIntensity = eI;
  innerBalloon.material.opacity = 0.25 + ph0 * 0.25;

  // Glass
  glassMat.opacity = 0.25 + ph0 * 0.2 + ph2 * 0.1;
  glassMat.transmission = 0.5 + ph0 * 0.2;

  // Gold edges
  goldEdges.material.opacity = 0.15 + eI * 0.12 + hoverIntensity * 0.1;

  // Typography
  typography.material.opacity = 0.15 + p * 0.55;
  typography.position.z = -4.5 - p * 1.0;
  typography.rotation.x = Math.sin(t * 0.05 + p * 2) * 0.008;
  typography.rotation.y = Math.sin(t * 0.03 + p) * 0.015;

  // Fog
  scene.fog.density = 0.015 + p * 0.035;

  // Ribbons
  ribbonGroup.children.forEach(r => {
    r.material.opacity = ph1 * 0.6;
    const s = 0.2 + ph1 * 0.8;
    r.scale.set(s, s, s);
    r.rotation.y += 0.003;
  });

  // Cluster balloons
  clusterGroup.children.forEach((m, i) => {
    m.material.opacity = ph2 * 0.6;
    const s = 0.01 + ph2 * 0.45;
    m.scale.set(s, s, s);
    const float = Math.sin(t * 0.6 + i * 1.3) * 0.03 * ph2;
    m.position.y += (cPositions[i][1] + float - m.position.y) * 0.02;
  });

  // Decorative lights
  decoGroup.children.forEach(l => {
    l.material.opacity = ph3 * 0.6 + hoverIntensity * 0.2;
    const { speed, offset, baseY } = l.userData;
    l.position.y = baseY + Math.sin(t * speed + offset) * 0.08;
    const s = 1 + Math.sin(t * speed * 1.5 + offset) * 0.3;
    l.scale.setScalar(s);
  });

  // Light rays
  rayGroup.children.forEach(r => {
    r.material.opacity = ph3 * 0.2 + ph4 * 0.1;
    r.rotation.z += 0.004;
  });

  // Floral accents
  floralGroup.children.forEach(a => {
    a.material.opacity = ph3 * 0.45;
  });

  // Particles - upward drift increases with scroll
  for (let i = 0; i < pCount; i++) {
    const idx = i * 3;
    pPositions[idx + 1] += Math.sin(t * 0.15 + i * 0.003) * 0.00015 + ph4 * 0.0004;
    pPositions[idx] += Math.cos(t * 0.1 + i * 0.003) * 0.00008;
    // Wrap around
    if (pPositions[idx + 1] > 9) pPositions[idx + 1] = -9;
    if (pPositions[idx] > 14) pPositions[idx] = -14;
    if (pPositions[idx] < -14) pPositions[idx] = 14;
  }
  particles.geometry.attributes.position.needsUpdate = true;
  particles.material.opacity = 0.25 + p * 0.45;

  // Bloom strength - subtle shift
  bloomPass.strength = 0.3 + p * 0.3 + hoverIntensity * 0.1;

  composer.render();
}
</script>
</body>
</html>